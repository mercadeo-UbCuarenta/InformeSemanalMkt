.crm-channel-head{display:flex;align-items:center;gap:12px}.channel-icon{width:40px;height:40px;display:grid;place-items:center;border-radius:12px;background:#f0ede7;font-size:18px}.crm-channel-head small{display:block;color:#918c84;font-size:8px;text-transform:uppercase;letter-spacing:.1em}.crm-channel-head h4{font-family:"Manrope";font-size:20px;margin:1px 0}.channel-status{margin-left:auto;border:1px solid #ddd8d0;border-radius:100px;padding:6px 8px;font-size:8px;font-weight:800}
.crm-primary{padding:25px 0 20px}.crm-primary>span{display:block;color:#89847d;font-size:10px;margin-bottom:7px}.crm-primary strong{font-family:"Manrope";font-size:25px}
.crm-metrics{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid #e8e5df}
.crm-metrics div{padding:15px 0;border-bottom:1px solid #e8e5df}.crm-metrics div:nth-child(odd){border-right:1px solid #e8e5df}.crm-metrics div:nth-child(even){padding-left:16px}
.crm-metrics span{display:block;color:#908b84;font-size:9px;margin-bottom:5px}.crm-metrics b{font-family:"Manrope";font-size:15px}
.email-channel .channel-icon{color:#b9122e;background:#fff0f1}.sms-channel .channel-icon{color:#315d91;background:#edf4fa}.whatsapp-channel .channel-icon{color:#18794e;background:#e9f7f0}
.crm-brand-table{background:#fff;border:1px solid #d8d4cd;border-radius:0 0 26px 26px;padding:28px}.crm-brand-table .panel-head{margin-bottom:12px}.crm-brand-table h3{font-family:"Manrope";font-size:22px;margin:5px 0}
.evidence-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px}.evidence-card{background:#fff;border:1px solid #dfdcd5;border-radius:26px;overflow:hidden;position:relative;transition:.25s}.evidence-card:hover{transform:translateY(-4px);box-shadow:var(--shadow)}.evidence-card.hidden{display:none}.evidence-card.featured{grid-column:span 2;display:grid;grid-template-columns:1.2fr 1fr}.evidence-card.featured.hidden{display:none}
.evidence-image{height:350px;position:relative;overflow:hidden;background:#ddd;cursor:zoom-in}.featured .evidence-image{height:100%;min-height:470px}.evidence-image img{width:100%;height:100%;object-fit:cover;transition:.35s}.evidence-card:hover .evidence-image img{transform:scale(1.025)}.card-brand{position:absolute;left:18px;top:18px;background:rgba(17,17,17,.82);color:white;border-radius:100px;padding:8px 12px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;backdrop-filter:blur(8px)}.card-action-type{position:absolute;right:18px;top:18px;max-width:55%;background:rgba(255,255,255,.9);color:#111;border-radius:100px;padding:8px 11px;font-size:9px;font-weight:800;text-align:right;backdrop-filter:blur(8px)}
.evidence-gallery{display:flex;gap:8px;padding:12px;background:#f5f3ef;overflow-x:auto;border-bottom:1px solid #dfdcd5}.featured .evidence-gallery{position:absolute;left:14px;right:14px;bottom:14px;z-index:4;border:0;border-radius:14px;background:rgba(245,243,239,.88);backdrop-filter:blur(12px)}.gallery-thumb{position:relative;flex:0 0 72px;width:72px;height:58px;padding:0;border:2px solid transparent;border-radius:9px;overflow:visible;background:#ddd}.gallery-thumb img{width:100%;height:100%;border-radius:7px;object-fit:cover}.gallery-thumb.active{border-color:var(--red)}.add-gallery-images{display:none;flex:0 0 72px;height:58px;border:1px dashed #8f8a82;border-radius:9px;background:transparent;color:#5d5953;font-size:10px;font-weight:800}.edit-mode .add-gallery-images{display:block}.remove-gallery-image{display:none;position:absolute;right:-6px;top:-7px;width:20px;height:20px;border-radius:50%;background:#b42318;color:#fff;font-size:14px;line-height:18px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.25);z-index:3}.edit-mode .remove-gallery-image{display:block}.edit-mode .evidence-image{cursor:pointer}
.evidence-body{padding:28px}.evidence-meta{display:flex;justify-content:space-between;align-items:center;text-transform:uppercase;letter-spacing:.09em;font-size:9px;font-weight:800;color:#8a867f}.evidence-card h3{font-family:"Manrope";font-size:28px;letter-spacing:-.04em;margin:14px 0 10px}.evidence-card p{font-size:14px;color:#6d6963;line-height:1.6}.channel-list{display:flex;gap:7px;flex-wrap:wrap;margin-top:22px}.channel-list span{font-size:10px;font-weight:700;border:1px solid #d9d5ce;padding:7px 10px;border-radius:100px}
.event-results{display:grid;grid-template-columns:repeat(3,1fr);margin-top:30px;border-top:1px solid var(--line);padding-top:24px;gap:15px}.event-results strong{font-family:"Manrope";font-size:25px;display:block}.event-results span{font-size:9px;text-transform:uppercase;color:#88847e}
.imported-results{display:flex;flex-wrap:wrap;gap:7px;margin-top:18px}.imported-results span{background:#f0ede7;border-radius:9px;padding:8px 10px;font-size:10px;font-weight:700}
.add-evidence{width:100%;border:1.5px dashed #bbb6ae;background:transparent;border-radius:22px;padding:28px;margin-top:22px;display:none;grid-template-columns:auto 1fr;column-gap:14px;text-align:left;align-items:center;color:#4f4b45}.add-evidence>span{grid-row:span 2;font-size:28px}.add-evidence b{font-size:13px}.add-evidence small{font-size:11px;color:#8c8881}.edit-mode .add-evidence{display:grid}.delete-card{display:none;position:absolute;top:16px;right:16px;width:34px;height:34px;border:0;border-radius:50%;background:#fff;color:#a51919;font-size:20px;box-shadow:0 4px 18px rgba(0,0,0,.18);z-index:3}.edit-mode .delete-card{display:block}
.image-edit-hint{display:none;position:absolute;inset:50% auto auto 50%;transform:translate(-50%,-50%);z-index:2;background:#fff;color:#111;border-radius:100px;padding:10px 15px;font-size:11px;font-weight:800;box-shadow:0 5px 20px rgba(0,0,0,.22);pointer-events:none}.edit-mode .evidence-image{cursor:pointer}.edit-mode .evidence-image:after{content:"";position:absolute;inset:0;background:rgba(0,0,0,.2);opacity:0;transition:.2s}.edit-mode .evidence-image:hover:after,.edit-mode .evidence-image:hover .image-edit-hint{opacity:1;display:block}
.conclusions{background:#e9e6e0}.decision-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.decision-grid article{padding:28px;background:#f6f4f0;border-radius:22px;min-height:260px;display:flex;flex-direction:column}.decision-grid article>span{font-family:"Manrope";font-size:13px;font-weight:800;color:var(--red)}.decision-grid article div{margin-top:auto}.decision-grid h3{font-family:"Manrope";font-size:22px;letter-spacing:-.03em}.decision-grid p{color:#6f6b65;line-height:1.55;font-size:14px}.closing-note{margin-top:18px;background:var(--ink);color:white;border-radius:24px;padding:30px 36px;display:grid;grid-template-columns:220px 1fr;align-items:center}.closing-note span{text-transform:uppercase;letter-spacing:.12em;font-size:10px;color:#aaa;font-weight:700}.closing-note p{font-family:"Manrope";font-size:22px;line-height:1.45;margin:0}
footer{height:140px;padding:0 5vw;display:flex;align-items:center;gap:25px;background:#fff;font-size:11px;color:#777}footer img{width:170px;margin-right:auto}
.editor-panel{position:fixed;right:24px;bottom:24px;width:370px;max-height:calc(100vh - 48px);overflow:auto;background:#191919;color:white;z-index:80;border-radius:24px;padding:22px;box-shadow:0 25px 80px rgba(0,0,0,.32);transform:translateY(calc(100% + 50px));transition:.35s}.editor-panel.open{transform:none}.editor-head{display:flex;justify-content:space-between;align-items:flex-start}.editor-head span{font-size:9px;text-transform:uppercase;letter-spacing:.13em;color:#999;display:block}.editor-head strong{font-size:16px}.editor-head button{border:0;background:#333;color:white;border-radius:50%;width:30px;height:30px;font-size:18px}.editor-panel>p{font-size:12px;line-height:1.5;color:#aaa}.editor-actions{display:grid;grid-template-columns:1fr 1fr;gap:7px}.editor-actions button,.file-action{border:1px solid #414141;background:#292929;color:white;border-radius:10px;padding:10px;font-size:10px;font-weight:700;text-align:center}.editor-actions .primary-action{grid-column:span 2;background:white;color:#111}.editor-actions .danger-action{color:#ff948d}.file-action input{display:none}.editor-panel>small{display:block;color:#777;font-size:9px;margin-top:12px}
.import-block{margin:16px 0;padding:15px;background:#242424;border:1px solid #383838;border-radius:14px;display:grid;grid-template-columns:1fr 1fr;gap:7px}.import-block>strong{grid-column:span 2;font-size:11px;margin-bottom:3px}.import-block .import-main{background:#fff;color:#111;border-color:#fff;padding:12px 8px}.template-link{grid-column:span 2;text-align:center;color:#ddd;border-bottom:1px solid #555;padding:7px 0 9px;font-size:10px;font-weight:700}.import-block small{grid-column:span 2;color:#888;font-size:9px;line-height:1.4}
.editable{outline:0;border-radius:4px}.edit-mode .editable{outline:1px dashed rgba(200,16,46,.55);outline-offset:3px;cursor:text}.edit-mode .editable:focus{background:#fff4c9;color:#111;outline:2px solid #d09a00}.edit-mode .kpi-dark .editable:focus,.edit-mode .brands-section .editable:focus{padding:2px}
.toast{position:fixed;left:50%;bottom:28px;z-index:100;background:#111;color:#fff;padding:12px 18px;border-radius:100px;font-size:12px;font-weight:700;opacity:0;transform:translate(-50%,20px);pointer-events:none;transition:.25s}.toast.show{opacity:1;transform:translate(-50%,0)}
.photo-viewer{position:fixed;z-index:120;inset:0;background:rgba(8,8,8,.94);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px;opacity:0;visibility:hidden;transition:.25s}.photo-viewer.open{opacity:1;visibility:visible}.photo-viewer>img{max-width:min(1200px,92vw);max-height:78vh;object-fit:contain;border-radius:10px;box-shadow:0 30px 90px rgba(0,0,0,.45)}.photo-viewer-close{position:absolute;right:30px;top:25px;width:44px;height:44px;border:1px solid #555;background:#222;color:#fff;border-radius:50%;font-size:26px}.photo-viewer-caption{width:min(1200px,92vw);display:flex;justify-content:space-between;gap:25px;color:#fff;margin-top:18px}.photo-viewer-caption strong{font-family:"Manrope";font-size:18px}.photo-viewer-caption span{font-size:11px;color:#aaa;text-transform:uppercase;letter-spacing:.1em}
@media(max-width:900px){
  .topbar{padding:0 20px}.topbar nav{display:none}.company{width:155px}
  .hero{height:auto;min-height:800px}.hero-grid{grid-template-columns:1fr}.hero-visual{height:350px}.hero-rings{width:310px;height:310px}.hero-stat{width:190px;height:190px}.hero-stat strong{font-size:55px}.brand-stack{right:0;width:150px}
  .section{padding:82px 0}.section-heading{align-items:flex-start;flex-direction:column;gap:20px}.section-intro{width:100%}
  .kpi-grid{grid-template-columns:1fr 1fr}.performance-grid{grid-template-columns:1fr}.brand-analysis{grid-template-columns:1fr}.brand-analysis-card{min-height:360px}
  .brand-focus-grid,.crm-channel-grid{grid-template-columns:1fr}.crm-channel-grid{gap:1px}.crm-intro{align-items:flex-start;flex-direction:column;gap:15px}.filter-group{grid-template-columns:1fr;gap:7px}
  .detail-controls{align-items:stretch;flex-direction:column}.detail-search{width:100%}
  .traffic-summary-cards{grid-template-columns:1fr 1fr}.traffic-dashboard-controls{align-items:stretch;flex-direction:column}.traffic-store-select{min-width:0;width:100%}
  .evidence-card.featured{grid-template-columns:1fr}.featured .evidence-image{min-height:350px}.featured .evidence-gallery{position:static;border-radius:0;background:#f5f3ef}.decision-grid{grid-template-columns:1fr}.closing-note{grid-template-columns:1fr;gap:14px}
}
@media(max-width:600px){
  .shell{width:min(100% - 28px,1180px)}.edit-toggle{padding:10px}.edit-toggle #editLabel{display:none}
  .hero{padding:110px 20px 30px}.hero h1{font-size:68px}.hero-period{font-size:16px}.hero-visual{margin-top:20px}.brand-stack{display:none}
  .kpi-grid,.evidence-grid{grid-template-columns:1fr}.evidence-card.featured{grid-column:auto;display:block}.evidence-image,.featured .evidence-image{height:280px;min-height:0}.event-results{grid-template-columns:1fr}
  .brand-focus,.commercial-detail{padding:20px}.brand-focus-grid{grid-template-columns:1fr}.focus-metrics{grid-template-columns:1fr 1fr}.crm-intro{padding:25px 20px}.crm-brand-table{padding:20px}.crm-channel{padding:20px}
  .traffic-summary-cards{grid-template-columns:1fr 1fr;padding:0 16px 16px}.traffic-dashboard-controls{padding:0 16px 16px}.traffic-daily-chart{margin:0 16px 18px;overflow-x:auto;justify-content:flex-start}.traffic-day{flex:0 0 42px}
  .actions-heading{align-items:flex-start}.action-filter-panel{padding:14px}.filters{width:100%;overflow:auto}.panel{padding:20px}.editor-panel{width:calc(100% - 24px);right:12px;bottom:12px}.closing-note{padding:25px}.closing-note p{font-size:18px}.photo-viewer{padding:18px}.photo-viewer-caption{flex-direction:column;gap:5px}.photo-viewer-close{right:14px;top:14px}
  footer{flex-wrap:wrap;height:auto;padding:35px 20px}footer p{width:100%;order:3}
}
@media print{
  .topbar,.editor-panel,.add-evidence,.delete-card,.scroll-hint,.action-filter-panel,.toast,.photo-viewer{display:none!important}
  body{background:white}.hero{height:720px;page-break-after:always}.section{padding:60px 0}.brands-section{print-color-adjust:exact;-webkit-print-color-adjust:exact}.evidence-card{break-inside:avoid}.evidence-grid{grid-template-columns:1fr 1fr}.conclusions{print-color-adjust:exact;-webkit-print-color-adjust:exact}
}
